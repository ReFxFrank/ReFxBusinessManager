{
  "name": "refx-business-manager",
  "version": "1.0.0",
  "private": true,
  "description": "All-in-one business manager for inventory sellers: buy → sell → profit loop, media gallery, and optional Facebook/Instagram publishing.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.2.1",
    "@radix-ui/react-dialog": "^1.1.4",
