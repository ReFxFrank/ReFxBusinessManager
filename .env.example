# ----------------------------------------------------------------------------
# ReFx Business Manager — environment configuration
# Copy this file to `.env` and adjust as needed.
# ----------------------------------------------------------------------------

# --- Database --------------------------------------------------------------
# SQLite single-file DB (easy backup). Swap to Postgres later by changing the
# provider in prisma/schema.prisma and this URL.
DATABASE_URL="file:./dev.db"

# --- Auth ------------------------------------------------------------------
# Single password-protected account. Set AUTH_ENABLED=false for purely-local,
# no-login use (e.g. on your own machine).
AUTH_ENABLED=true
# The demo login password (used by the seed/login). Change for real use.
AUTH_PASSWORD="demo1234"
# Secret used to sign the session cookie. Change to a long random string.
AUTH_SECRET="change-me-to-a-long-random-secret-string"

# --- Public base URL -------------------------------------------------------
# REQUIRED for Instagram publishing: Instagram fetches media from a public URL.
# Locally, expose this app with a tunnel (ngrok/cloudflared) and put the public
# https URL here. Leave as localhost for normal local use (IG publish disabled).
PUBLIC_BASE_URL="http://localhost:3000"

# --- Media limits ----------------------------------------------------------
MAX_IMAGE_SIZE_MB=15
MAX_VIDEO_SIZE_MB=200
MAX_VIDEO_DURATION_SECONDS=60

# --- Platform integrations: Shopify & Etsy (OPTIONAL) ----------------------
# Shopify: a CUSTOM APP needs no app-level keys here — you connect in-app by
# entering your shop domain + Admin API access token. The key/secret below are
# only needed for the public-app OAuth flow.
SHOPIFY_API_VERSION="2026-01"
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_OAUTH_REDIRECT_URI="http://localhost:3000/api/integrations/shopify/oauth/callback"

# Etsy Open API v3: the keystring is your app's x-api-key (REQUIRED to enable
# Etsy). Listing/receipt access uses OAuth2; production access needs Etsy app
# review (dev/personal access works immediately).
ETSY_KEYSTRING=""
ETSY_SHARED_SECRET=""
ETSY_OAUTH_REDIRECT_URI="http://localhost:3000/api/integrations/etsy/oauth/callback"

# --- Meta / Facebook / Instagram (OPTIONAL) --------------------------------
# The whole social-publishing feature is gated by configuration. If these are
# unset, the app still runs and share buttons show setup guidance + a
# "copy caption & open platform" fallback instead of erroring.
# Create a Meta app at https://developers.facebook.com/ and fill these in.
META_APP_ID=""
META_APP_SECRET=""
# OAuth redirect — must match the URI registered in your Meta app settings.
META_OAUTH_REDIRECT_URI="http://localhost:3000/api/social/oauth/callback"
# Graph API version (verify the current version in Meta's docs).
META_GRAPH_VERSION="v21.0"
